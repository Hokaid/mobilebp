# Node.js and React Native

# Ignore node_modules folders anywhere in the repository
**/node_modules/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependency directories
jspm_packages/

# Optional cache directories
.npm
.pnpm-store/

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn v2 and above
.yarn/*
!.yarn/cache
!.yarn/patches
!.yarn/releases
!.yarn/plugins
!.yarn/sdks
!.yarn/versions
.pnp.*
.pnp

# Storybook build outputs
.out
.storybook-out

# Build directories
dist/
build/
tmp/
temp/
cache/

# Mac system files
.DS_Store

# Visual Studio Code
.vscode/

# IntelliJ IDEA
.idea/

# Temporary files
*.swp
*.swo

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# React Native packager cache
.expo
.expo-shared
*.expo

# Metro bundler cache
**/react-native/packager-cache/*
**/react-native-packager-cache-*/

# Haste cache
**/react-native/haste-map-*/

# Android/IntelliJ
**/android/app/build/
**/android/build/
**/android/.gradle/
**/android/.idea/
**/android/local.properties

# iOS/Xcode
**/ios/build/
**/ios/Pods/
**/ios/Podfile.lock
**/ios/.DS_Store
**/ios/*.xcworkspace
**/ios/*.xcuserstate
**/ios/*/ArchiveIntermediates/
**/ios/*/Build/
**/ios/*/*.xcodeproj/xcuserdata/

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output

# CocoaPods
.cocoapods/

# Additional files to ignore
npm-debug.log*
yarn-debug.log*
lerna-debug.log*
.*.swp